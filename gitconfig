[user]
  name = Anton Holmgren
  email = me@antonholmgren.com

[core]
	excludesfile = /Users/anton/.gitignore_global

[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path =

[mergetool "sourcetree"]
	cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true

[github]
  user = alksl

[alias]
  co = checkout
  ci = commit
  st = status
  f  = commit --fixup
  lo = log --oneline
  squash = rebase -i --autosquash master
  b = checkout -b

[push]
  default = upstream

[ui]
  color = auto

[color]
  ui = auto
[fetch]
	prune = true
[remote "origin"]
	prune = true
