#!/bin/bash
# Git worktree management tool

source "$(dirname "$0")/log.sh"

usage() {
    echo "Usage: wt new <branch-name>"
    echo "       wt switch [-c] <branch-name>"
    echo "       wt sw [-c] <branch-name>"
    echo "       wt rm <branch-name>"
    echo "       wt list"
    echo "       wt prune          # remove worktrees merged into default branch"
}

cmd_new() {
    local branch="$1"

    if [ -z "$branch" ]; then
        usage
        exit 1
    fi

    # Always derive the path from the main worktree so that running wt new
    # from inside a linked worktree doesn't produce repo-branch1-branch2.
    local main_worktree=""
    while IFS= read -r line; do
        case "$line" in
            "worktree "*) main_worktree="${line#worktree }"; break ;;
        esac
    done < <(git worktree list --porcelain 2>/dev/null)

    if [ -z "$main_worktree" ]; then
        error "Not inside a git repository"
        exit 1
    fi

    local repo_name
    repo_name=$(basename "$main_worktree")

    local worktree_path
    worktree_path="$(dirname "$main_worktree")/${repo_name}-${branch}"

    # Check if a worktree already exists on this branch
    local existing_worktree=""
    local cur_wt=""
    while IFS= read -r line; do
        case "$line" in
            "worktree "*)  cur_wt="${line#worktree }" ;;
            "branch refs/heads/${branch}")  existing_worktree="$cur_wt"; break ;;
        esac
    done < <(git worktree list --porcelain)

    if [ -n "$existing_worktree" ]; then
        error "A worktree for branch '$branch' already exists at: $existing_worktree"
        exit 1
    fi

    # Check if target directory already exists
    if [ -d "$worktree_path" ]; then
        error "Target directory already exists: $worktree_path"
        exit 1
    fi

    if git show-ref --verify --quiet "refs/heads/$branch"; then
        log "Using existing branch '$branch'"
    elif git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        log "Creating local branch '$branch' tracking origin/$branch"
        git branch "$branch" "origin/$branch"
    else
        log "Creating branch '$branch' from HEAD"
        git branch "$branch"
    fi

    log "Creating worktree at $worktree_path"
    git worktree add "$worktree_path" "$branch"
    log "Done: $worktree_path"
}

cmd_switch() {
    local create=0
    if [ "$1" = "-c" ]; then
        create=1
        shift
    fi

    local branch="$1"

    if [ -z "$branch" ]; then
        usage
        exit 1
    fi

    # Validate we're inside a git repo
    local toplevel
    toplevel=$(git rev-parse --show-toplevel 2>/dev/null)
    if [ -z "$toplevel" ]; then
        error "Not inside a git repository"
        exit 1
    fi

    if [ "$create" -eq 1 ]; then
        # Create the branch + worktree; cmd_new exits non-zero on failure.
        # Redirect its stdout to stderr so only the path we echo below
        # reaches the shell wrapper that cd's into it.
        cmd_new "$branch" >&2 || exit $?
    fi

    # Find the main worktree (always the first entry in the list)
    local main_worktree
    main_worktree=$(git worktree list --porcelain | awk '/^worktree /{print $2; exit}')

    local main_name
    main_name=$(basename "$main_worktree")

    local parent
    parent=$(dirname "$main_worktree")

    # "main" and "master" always go to the main worktree
    local main_branch
    main_branch=$(git -C "$main_worktree" symbolic-ref --short HEAD 2>/dev/null)

    local worktree_path
    if [ "$branch" = "main" ] || [ "$branch" = "master" ] || [ "$branch" = "$main_branch" ]; then
        worktree_path="$main_worktree"
    else
        worktree_path="${parent}/${main_name}-${branch}"
    fi

    if [ ! -d "$worktree_path" ]; then
        error "No worktree found for branch '$branch' at: $worktree_path"
        exit 1
    fi

    # Print the path so the shell function can cd to it
    echo "$worktree_path"
}

cmd_complete() {
    local subcmd="$1"
    case "$subcmd" in
        switch|sw)
            git worktree list --porcelain 2>/dev/null | awk '/^branch /{sub("refs/heads/", "", $2); print $2}'
            ;;
        rm)
            # Exclude the main worktree (first entry)
            git worktree list --porcelain 2>/dev/null | awk '/^worktree /{wt=$2} /^branch /{sub("refs/heads/", "", $2); print wt, $2}' | tail -n +2 | awk '{print $2}'
            ;;
        *)
            exit 1
            ;;
    esac
}

cmd_rm() {
    local branch="$1"

    if [ -z "$branch" ]; then
        usage
        exit 1
    fi

    local worktree_path
    worktree_path=$(git worktree list --porcelain | awk '/^worktree /{wt=$2} /^branch refs\/heads\/'"$branch"'$/{print wt}')

    if [ -z "$worktree_path" ]; then
        error "No worktree found for branch '$branch'"
        exit 1
    fi

    git worktree remove "$worktree_path"
}

cmd_list() {
    git worktree list
}

cmd_prune() {
    local default_branch
    default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')

    if [ -z "$default_branch" ]; then
        if git show-ref --verify --quiet refs/heads/main; then
            default_branch="main"
        elif git show-ref --verify --quiet refs/heads/master; then
            default_branch="master"
        else
            error "Could not determine default branch"
            exit 1
        fi
    fi

    log "Using default branch: $default_branch"

    local pruned=0
    local skip_main=1
    local wt_path=""
    local branch=""

    while IFS= read -r line; do
        case "$line" in
            "worktree "*)
                wt_path="${line#worktree }"
                branch=""
                ;;
            "branch "*)
                branch="${line#branch refs/heads/}"
                ;;
            "")
                if [ "$skip_main" -eq 1 ]; then
                    skip_main=0
                elif [ -n "$branch" ] && git merge-base --is-ancestor "$branch" "$default_branch" 2>/dev/null; then
                    log "Removing merged worktree: $wt_path (branch: $branch)"
                    git worktree remove "$wt_path"
                    pruned=$((pruned + 1))
                fi
                wt_path=""
                branch=""
                ;;
        esac
    done < <(git worktree list --porcelain && echo)

    if [ "$pruned" -eq 0 ]; then
        log "No merged worktrees found"
    fi
}

# Parse subcommand
case "$1" in
    new)
        shift
        cmd_new "$@"
        ;;
    switch|sw)
        shift
        cmd_switch "$@"
        ;;
    list)
        shift
        cmd_list "$@"
        ;;
    prune)
        shift
        cmd_prune "$@"
        ;;
    rm)
        shift
        cmd_rm "$@"
        ;;
    complete)
        shift
        cmd_complete "$@"
        ;;
    *)
        usage
        exit 1
        ;;
esac
